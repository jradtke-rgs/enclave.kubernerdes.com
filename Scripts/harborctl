#!/bin/bash
set -euo pipefail

# harborctl — Manage Harbor on nuc-00
#
# Run as root (or via sudo) on nuc-00.
#
# Usage:
#   harborctl start       — Start Harbor containers and wait for healthy
#   harborctl stop        — Stop Harbor containers
#   harborctl status      — Show container state, health, and cert info
#   harborctl trustcert   — Re-sign Harbor TLS cert with current enclave CA
#                           (use after CA rotation), then restart Harbor
#   harborctl enable      — Install systemd unit so Harbor starts on boot
#   harborctl disable     — Remove the systemd auto-start unit

HARBOR_INSTALL_DIR="/opt/harbor"
HARBOR_HOSTNAME="harbor.enclave.kubernerdes.com"
HARBOR_CERT_DIR="${HARBOR_INSTALL_DIR}/certs"
CA_DIR="/etc/ssl/enclave-ca"

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------
harbor_compose() {
  cd "${HARBOR_INSTALL_DIR}" && docker compose "$@"
}

wait_healthy() {
  echo "==> Waiting for Harbor to be ready..."
  for i in $(seq 1 24); do
    if curl -sk "https://${HARBOR_HOSTNAME}/api/v2.0/health" 2>/dev/null | grep -q "healthy"; then
      echo "    Harbor is healthy."
      return 0
    fi
    echo "    Waiting... (${i}/24)"
    sleep 5
  done
  echo "ERROR: Harbor did not become healthy within 2 minutes."
  harbor_compose ps
  exit 1
}

# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------
cmd_start() {
  echo "==> Starting Harbor"
  harbor_compose up -d
  wait_healthy
}

cmd_stop() {
  echo "==> Stopping Harbor"
  harbor_compose down
  echo "    Harbor stopped."
}

cmd_status() {
  echo "==> Container status"
  harbor_compose ps
  echo

  echo "==> Health check"
  HEALTH=$(curl -sk "https://${HARBOR_HOSTNAME}/api/v2.0/health" 2>/dev/null || echo '{"status":"unreachable"}')
  echo "    ${HEALTH}"
  echo

  echo "==> TLS certificate"
  if [[ -f "${HARBOR_CERT_DIR}/harbor.crt" ]]; then
    openssl x509 -in "${HARBOR_CERT_DIR}/harbor.crt" -noout -subject -issuer -dates
    if openssl verify -CAfile "${CA_DIR}/ca.crt" "${HARBOR_CERT_DIR}/harbor.crt" &>/dev/null; then
      echo "    Cert verification: OK (trusted by enclave CA)"
    else
      echo "    Cert verification: FAILED — cert not signed by current enclave CA"
      echo "    Run: harborctl trustcert"
    fi
  else
    echo "    No cert found at ${HARBOR_CERT_DIR}/harbor.crt"
  fi
}

cmd_enable() {
  echo "==> Enabling Harbor auto-start on boot"
  cat << 'UNIT' > /etc/systemd/system/harbor.service
[Unit]
Description=Harbor Container Registry
After=docker.service network-online.target
Requires=docker.service

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/opt/harbor
ExecStart=/usr/bin/docker compose up -d
ExecStop=/usr/bin/docker compose down
TimeoutStartSec=180

[Install]
WantedBy=multi-user.target
UNIT
  systemctl daemon-reload
  systemctl enable harbor.service
  echo "    Harbor will now start automatically on boot."
  echo "    Use 'harborctl start' to start Harbor now."
}

cmd_disable() {
  echo "==> Disabling Harbor auto-start on boot"
  systemctl disable harbor.service 2>/dev/null || true
  rm -f /etc/systemd/system/harbor.service
  systemctl daemon-reload
  echo "    Harbor auto-start disabled."
}

cmd_trustcert() {
  if [[ ! -f "${CA_DIR}/ca.crt" || ! -f "${CA_DIR}/ca.key" ]]; then
    echo "ERROR: Enclave CA not found at ${CA_DIR}. Run 02_setup_ca.sh first."
    exit 1
  fi

  echo "==> Re-signing Harbor TLS certificate with current enclave CA"
  mkdir -p "${HARBOR_CERT_DIR}"

  openssl genrsa -out "${HARBOR_CERT_DIR}/harbor.key" 4096
  openssl req -new \
    -key  "${HARBOR_CERT_DIR}/harbor.key" \
    -out  /tmp/harbor.csr \
    -subj "/CN=${HARBOR_HOSTNAME}/O=enclave/C=US"
  printf "subjectAltName=IP:10.10.12.10,DNS:harbor.enclave.kubernerdes.com,DNS:nuc-00.enclave.kubernerdes.com" \
    > /tmp/harbor.ext
  openssl x509 -req -days 730 \
    -in      /tmp/harbor.csr \
    -CA      "${CA_DIR}/ca.crt" \
    -CAkey   "${CA_DIR}/ca.key" \
    -CAcreateserial \
    -out     "${HARBOR_CERT_DIR}/harbor.crt" \
    -extfile /tmp/harbor.ext
  rm -f /tmp/harbor.csr /tmp/harbor.ext

  echo "    New cert issued:"
  openssl x509 -in "${HARBOR_CERT_DIR}/harbor.crt" -noout -subject -issuer -dates

  echo "==> Restarting Harbor to apply new certificate"
  harbor_compose restart
  wait_healthy
}

# ---------------------------------------------------------------------------
# Dispatch
# ---------------------------------------------------------------------------
if [[ "$(id -u)" -ne 0 ]]; then
  echo "ERROR: harborctl must be run as root."
  exit 1
fi

case "${1:-}" in
  start)     cmd_start ;;
  stop)      cmd_stop ;;
  status)    cmd_status ;;
  trustcert) cmd_trustcert ;;
  enable)    cmd_enable ;;
  disable)   cmd_disable ;;
  *)
    echo "Usage: harborctl {start|stop|status|trustcert|enable|disable}"
    exit 1
    ;;
esac
