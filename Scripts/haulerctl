#!/bin/bash
set -euo pipefail

# haulerctl — Manage hauler stores on nuc-00
#
# Run as root (or via sudo) on nuc-00.
#
# Usage:
#   haulerctl sync                   — Pull/update all artifacts into hauler stores
#                                      (version pins live in Scripts/01_hauler_sync.sh)
#   haulerctl serve [fileserver]     — Start the fileserver in the background (port 8080)
#                                      Files served at http://host:8080/<name> (no prefix)
#   haulerctl serve registry <store> — Start a store's OCI registry (port 5000)
#   haulerctl status                 — Show store inventory and server state
#   haulerctl push [<store>|all]     — Push store(s) to Harbor via hauler store copy
#   haulerctl enable                 — Install systemd units so fileserver starts on boot
#   haulerctl disable                — Remove the systemd auto-start units
#
# Store → Harbor project mapping:
#   rancher           → harbor/rancher
#   rke2              → harbor  (NO project prefix — images land at harbor/rancher/rke2-runtime)
#                        Required because system-default-registry is RFC 3986 hostname-only;
#                        the bootstrap image pull constructs: {registry}/{image-name} directly.
#   neuvector         → harbor/neuvector
#   harvester         → harbor/harvester
#   carbide-images    → harbor/carbide
#   third-party-charts→ harbor/third-party-charts
#   files             → (not pushed — served via fileserver only)

HAULER_STORE_DIR="${HAULER_STORE_DIR:-/root/hauler/store}"
HARBOR_HOSTNAME="harbor.enclave.kubernerdes.com"
HARBOR_ADMIN_USER="admin"
HARBOR_ADMIN_PASSWORD="${GENERIC_PASSWORD}"
FILESERVER_PORT=8080
REGISTRY_PORT=5000

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Resolve hauler binary — sudo strips /usr/local/bin from PATH
HAULER=$(command -v hauler 2>/dev/null || echo /usr/local/bin/hauler)
if [[ ! -x "${HAULER}" ]]; then
  echo "ERROR: hauler binary not found. Run Scripts/00_install_hauler.sh first."
  exit 1
fi

# Store name → Harbor project (empty = no project prefix)
declare -A STORE_PROJECT=(
  [rancher]="rancher"
  [rke2]=""
  [neuvector]="neuvector"
  [harvester]="harvester"
  [carbide-images]="carbide"
  [third-party-charts]="third-party-charts"
)

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------
port_listening() {
  ss -tlnp 2>/dev/null | grep -q ":${1} " || \
    netstat -tlnp 2>/dev/null | grep -q ":${1} "
}

# ---------------------------------------------------------------------------
# sync
# ---------------------------------------------------------------------------
cmd_sync() {
  echo "==> Delegating to 01_hauler_sync.sh (version pins live there)"
  exec bash "${SCRIPT_DIR}/01_hauler_sync.sh"
}

# ---------------------------------------------------------------------------
# serve
# ---------------------------------------------------------------------------
cmd_serve() {
  local mode="${1:-fileserver}"

  case "${mode}" in
    fileserver)
      local store="${HAULER_STORE_DIR}/files"
      if [[ ! -d "${store}" ]]; then
        echo "ERROR: Files store not found at ${store}. Run haulerctl sync first."
        exit 1
      fi
      if port_listening "${FILESERVER_PORT}"; then
        echo "==> Fileserver already listening on port ${FILESERVER_PORT}."
        return 0
      fi
      echo "==> Starting hauler fileserver on port ${FILESERVER_PORT} (background)"
      nohup "${HAULER}" store serve fileserver \
        --store "${store}" \
        --port "${FILESERVER_PORT}" \
        >> /var/log/hauler-fileserver.log 2>&1 &
      sleep 2
      if port_listening "${FILESERVER_PORT}"; then
        echo "    Fileserver is up. Log: /var/log/hauler-fileserver.log"
        echo "    Files served at: http://$(hostname -I | awk '{print $1}'):${FILESERVER_PORT}/<name>"
      else
        echo "ERROR: Fileserver did not start. Check /var/log/hauler-fileserver.log"
        exit 1
      fi
      ;;

    registry)
      local store_name="${2:-}"
      if [[ -z "${store_name}" ]]; then
        echo "Usage: haulerctl serve registry <store>"
        echo "Available stores: ${!STORE_PROJECT[*]}"
        exit 1
      fi
      local store="${HAULER_STORE_DIR}/${store_name}"
      if [[ ! -d "${store}" ]]; then
        echo "ERROR: Store not found at ${store}. Run haulerctl sync first."
        exit 1
      fi
      if port_listening "${REGISTRY_PORT}"; then
        echo "==> Registry already listening on port ${REGISTRY_PORT}."
        return 0
      fi
      echo "==> Starting hauler registry for store '${store_name}' on port ${REGISTRY_PORT} (background)"
      nohup "${HAULER}" store serve registry \
        --store "${store}" \
        --port "${REGISTRY_PORT}" \
        --readonly=false \
        >> /var/log/hauler-registry.log 2>&1 &
      sleep 2
      if port_listening "${REGISTRY_PORT}"; then
        echo "    Registry is up. Log: /var/log/hauler-registry.log"
      else
        echo "ERROR: Registry did not start. Check /var/log/hauler-registry.log"
        exit 1
      fi
      ;;

    *)
      echo "Usage: haulerctl serve [fileserver|registry <store>]"
      exit 1
      ;;
  esac
}

# ---------------------------------------------------------------------------
# status
# ---------------------------------------------------------------------------
cmd_status() {
  echo "==> Servers"
  if port_listening "${FILESERVER_PORT}"; then
    echo "    Fileserver : UP   (port ${FILESERVER_PORT})"
  else
    echo "    Fileserver : DOWN (port ${FILESERVER_PORT})"
  fi
  if port_listening "${REGISTRY_PORT}"; then
    echo "    Registry   : UP   (port ${REGISTRY_PORT})"
  else
    echo "    Registry   : DOWN (port ${REGISTRY_PORT})"
  fi

  echo
  echo "==> Stores under ${HAULER_STORE_DIR}"
  if [[ ! -d "${HAULER_STORE_DIR}" ]]; then
    echo "    Store directory not found — run haulerctl sync first."
    return 0
  fi

  local found=0
  for store_dir in "${HAULER_STORE_DIR}"/*/; do
    [[ -d "${store_dir}" ]] || continue
    local name
    name="$(basename "${store_dir}")"
    local size
    size="$(du -sh "${store_dir}" 2>/dev/null | cut -f1)"
    local dest
    if [[ -n "${STORE_PROJECT[${name}]:-}" ]]; then
      dest="${HARBOR_HOSTNAME}/${STORE_PROJECT[${name}]}"
    elif [[ "${name}" == "files" ]]; then
      dest="fileserver-only"
    else
      dest="${HARBOR_HOSTNAME} (no prefix)"
    fi
    printf "    %-22s  %6s  → %s\n" "${name}" "${size}" "${dest}"
    found=1
  done

  if [[ "${found}" -eq 0 ]]; then
    echo "    No stores found — run haulerctl sync first."
  fi
}

# ---------------------------------------------------------------------------
# push — uses hauler store copy (no crane dependency)
# ---------------------------------------------------------------------------
push_one_store() {
  local store_name="$1"
  local project="${STORE_PROJECT[${store_name}]:-UNKNOWN}"
  local store_path="${HAULER_STORE_DIR}/${store_name}"

  if [[ "${project}" == "UNKNOWN" ]]; then
    echo "    Skipping ${store_name} — not in STORE_PROJECT mapping"
    return 0
  fi

  if [[ ! -d "${store_path}" ]]; then
    echo "    Skipping ${store_name} — store not found at ${store_path}"
    return 0
  fi

  if [[ -n "${project}" ]]; then
    echo "==> Pushing ${store_name} → ${HARBOR_HOSTNAME}/${project}"
    "${HAULER}" store copy \
      --store "${store_path}" \
      "registry://${HARBOR_HOSTNAME}/${project}"
  else
    echo "==> Pushing ${store_name} → ${HARBOR_HOSTNAME} (no project prefix)"
    "${HAULER}" store copy \
      --store "${store_path}" \
      "registry://${HARBOR_HOSTNAME}"
  fi
}

cmd_push() {
  local target="${1:-all}"

  echo "==> Logging hauler into Harbor"
  "${HAULER}" login "${HARBOR_HOSTNAME}" \
    -u "${HARBOR_ADMIN_USER}" \
    -p "${HARBOR_ADMIN_PASSWORD}"

  if [[ "${target}" == "all" ]]; then
    for store_name in "${!STORE_PROJECT[@]}"; do
      push_one_store "${store_name}"
    done
  else
    if [[ -z "${STORE_PROJECT[${target}]+x}" ]]; then
      echo "ERROR: Unknown store '${target}'."
      echo "Known stores: ${!STORE_PROJECT[*]}"
      exit 1
    fi
    push_one_store "${target}"
  fi

  echo
  echo "==> Push complete. Verify in Harbor: https://${HARBOR_HOSTNAME}"
}

# ---------------------------------------------------------------------------
# enable / disable — systemd auto-start for the fileserver
#
# The fileserver (port 8080) is the only service that must survive a reboot
# during a node install run. The registry (port 5000) is only needed during
# haulerctl push and can be started on demand.
# ---------------------------------------------------------------------------
cmd_enable() {
  echo "==> Enabling hauler fileserver auto-start on boot"
  cat > /etc/systemd/system/hauler-fileserver.service << UNIT
[Unit]
Description=Hauler Fileserver (RKE2 install scripts and binaries)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=${HAULER} store serve fileserver --store ${HAULER_STORE_DIR}/files --port ${FILESERVER_PORT}
Restart=on-failure
StandardOutput=append:/var/log/hauler-fileserver.log
StandardError=append:/var/log/hauler-fileserver.log

[Install]
WantedBy=multi-user.target
UNIT
  systemctl daemon-reload
  systemctl enable hauler-fileserver.service
  echo "    Hauler fileserver will start automatically on boot."
  echo "    Use 'haulerctl serve fileserver' or 'systemctl start hauler-fileserver' to start now."
}

cmd_disable() {
  echo "==> Disabling hauler fileserver auto-start on boot"
  systemctl disable hauler-fileserver.service 2>/dev/null || true
  rm -f /etc/systemd/system/hauler-fileserver.service
  systemctl daemon-reload
  echo "    Hauler fileserver auto-start disabled."
}

# ---------------------------------------------------------------------------
# Dispatch
# ---------------------------------------------------------------------------
if [[ "$(id -u)" -ne 0 ]]; then
  echo "ERROR: haulerctl must be run as root."
  exit 1
fi

case "${1:-}" in
  sync)    cmd_sync ;;
  serve)   shift; cmd_serve "$@" ;;
  status)  cmd_status ;;
  push)    shift; cmd_push "${1:-all}" ;;
  enable)  cmd_enable ;;
  disable) cmd_disable ;;
  *)
    echo "Usage: haulerctl {sync|serve [fileserver|registry <store>]|status|push [<store>|all]|enable|disable}"
    exit 1
    ;;
esac
