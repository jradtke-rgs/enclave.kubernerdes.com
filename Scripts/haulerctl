#!/bin/bash
set -euo pipefail

# haulerctl — Manage hauler stores on nuc-00
#
# Run as root (or via sudo) on nuc-00.
#
# Usage:
#   haulerctl sync                  — Pull/update all artifacts into hauler stores
#                                     (version pins live in Scripts/01_hauler_sync.sh)
#   haulerctl serve [fileserver]    — Start the fileserver in the background (port 8080)
#                                     Serves RKE2 install script and other binaries to nodes
#   haulerctl serve registry <store>— Start a store's OCI registry in the background (port 5000)
#   haulerctl status                — Show store inventory and whether servers are listening
#   haulerctl push [<store>|all]    — Push store(s) to Harbor via crane
#
# Store → Harbor project mapping:
#   rancher           → harbor/rancher
#   rke2              → harbor/rke2
#   neuvector         → harbor/neuvector
#   harvester         → harbor/harvester
#   carbide-images    → harbor/carbide
#   third-party-charts→ harbor/third-party-charts
#   files             → (not pushed — served via fileserver only)

HAULER_STORE_DIR="${HAULER_STORE_DIR:-/root/hauler/store}"
HARBOR_HOSTNAME="harbor.enclave.kubernerdes.com"
HARBOR_ADMIN_PASSWORD="Passw0rd01"
FILESERVER_PORT=8080
REGISTRY_PORT=5000
PUSH_REGISTRY_PORT=15000   # ephemeral port used during push; avoids clashing with serve

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Store name → Harbor project (files excluded — fileserver only)
declare -A STORE_PROJECT=(
  [rancher]="rancher"
  [rke2]="rke2"
  [neuvector]="neuvector"
  [harvester]="harvester"
  [carbide-images]="carbide"
  [third-party-charts]="third-party-charts"
)

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------
port_listening() {
  ss -tlnp 2>/dev/null | grep -q ":${1} " || \
    netstat -tlnp 2>/dev/null | grep -q ":${1} "
}

require_crane() {
  if ! command -v crane &>/dev/null; then
    echo "ERROR: crane is not installed. Install it first:"
    echo "  CRANE_VERSION=\$(curl -sf https://api.github.com/repos/google/go-containerregistry/releases/latest | python3 -c \"import sys,json; print(json.load(sys.stdin)['tag_name'])\")"
    echo "  curl -sfL \"https://github.com/google/go-containerregistry/releases/download/\${CRANE_VERSION}/go-containerregistry_Linux_x86_64.tar.gz\" | tar -xz -C /usr/local/bin crane"
    exit 1
  fi
}

# ---------------------------------------------------------------------------
# sync
# ---------------------------------------------------------------------------
cmd_sync() {
  echo "==> Delegating to 01_hauler_sync.sh (version pins live there)"
  exec bash "${SCRIPT_DIR}/01_hauler_sync.sh"
}

# ---------------------------------------------------------------------------
# serve
# ---------------------------------------------------------------------------
cmd_serve() {
  local mode="${1:-fileserver}"

  case "${mode}" in
    fileserver)
      local store="${HAULER_STORE_DIR}/files"
      if [[ ! -d "${store}" ]]; then
        echo "ERROR: Files store not found at ${store}. Run haulerctl sync first."
        exit 1
      fi
      if port_listening "${FILESERVER_PORT}"; then
        echo "==> Fileserver already listening on port ${FILESERVER_PORT}."
        return 0
      fi
      echo "==> Starting hauler fileserver on port ${FILESERVER_PORT} (background)"
      nohup hauler store serve fileserver \
        --store "${store}" \
        --port "${FILESERVER_PORT}" \
        >> /var/log/hauler-fileserver.log 2>&1 &
      sleep 2
      if port_listening "${FILESERVER_PORT}"; then
        echo "    Fileserver is up. Log: /var/log/hauler-fileserver.log"
      else
        echo "ERROR: Fileserver did not start. Check /var/log/hauler-fileserver.log"
        exit 1
      fi
      ;;

    registry)
      local store_name="${2:-}"
      if [[ -z "${store_name}" ]]; then
        echo "Usage: haulerctl serve registry <store>"
        echo "Available stores: ${!STORE_PROJECT[*]}"
        exit 1
      fi
      local store="${HAULER_STORE_DIR}/${store_name}"
      if [[ ! -d "${store}" ]]; then
        echo "ERROR: Store not found at ${store}. Run haulerctl sync first."
        exit 1
      fi
      if port_listening "${REGISTRY_PORT}"; then
        echo "==> Registry already listening on port ${REGISTRY_PORT}."
        return 0
      fi
      echo "==> Starting hauler registry for store '${store_name}' on port ${REGISTRY_PORT} (background)"
      nohup hauler store serve registry \
        --store "${store}" \
        --port "${REGISTRY_PORT}" \
        --readonly=false \
        >> /var/log/hauler-registry.log 2>&1 &
      sleep 2
      if port_listening "${REGISTRY_PORT}"; then
        echo "    Registry is up. Log: /var/log/hauler-registry.log"
      else
        echo "ERROR: Registry did not start. Check /var/log/hauler-registry.log"
        exit 1
      fi
      ;;

    *)
      echo "Usage: haulerctl serve [fileserver|registry <store>]"
      exit 1
      ;;
  esac
}

# ---------------------------------------------------------------------------
# status
# ---------------------------------------------------------------------------
cmd_status() {
  echo "==> Servers"
  if port_listening "${FILESERVER_PORT}"; then
    echo "    Fileserver : UP   (port ${FILESERVER_PORT})"
  else
    echo "    Fileserver : DOWN (port ${FILESERVER_PORT})"
  fi
  if port_listening "${REGISTRY_PORT}"; then
    echo "    Registry   : UP   (port ${REGISTRY_PORT})"
  else
    echo "    Registry   : DOWN (port ${REGISTRY_PORT})"
  fi

  echo
  echo "==> Stores under ${HAULER_STORE_DIR}"
  if [[ ! -d "${HAULER_STORE_DIR}" ]]; then
    echo "    Store directory not found — run haulerctl sync first."
    return 0
  fi

  local found=0
  for store_dir in "${HAULER_STORE_DIR}"/*/; do
    [[ -d "${store_dir}" ]] || continue
    local name
    name="$(basename "${store_dir}")"
    local size
    size="$(du -sh "${store_dir}" 2>/dev/null | cut -f1)"
    local project="${STORE_PROJECT[${name}]:-fileserver-only}"
    printf "    %-22s  %6s  → %s\n" "${name}" "${size}" "${project}"
    found=1
  done

  if [[ "${found}" -eq 0 ]]; then
    echo "    No stores found — run haulerctl sync first."
  fi
}

# ---------------------------------------------------------------------------
# push
# ---------------------------------------------------------------------------
push_one_store() {
  local store_name="$1"
  local project="${STORE_PROJECT[${store_name}]}"
  local store_path="${HAULER_STORE_DIR}/${store_name}"

  if [[ ! -d "${store_path}" ]]; then
    echo "    Skipping ${store_name} — store not found at ${store_path}"
    return 0
  fi

  echo "==> Pushing ${store_name} → ${HARBOR_HOSTNAME}/${project}"

  # Serve the store on an ephemeral port so crane can read it
  hauler store serve registry \
    --store "${store_path}" \
    --port "${PUSH_REGISTRY_PORT}" \
    --readonly=true >> /var/log/hauler-push.log 2>&1 &
  local HAULER_PID=$!
  sleep 3

  local pushed=0 skipped=0
  for REF in $(crane catalog "localhost:${PUSH_REGISTRY_PORT}" --insecure 2>/dev/null); do
    for TAG in $(crane ls "localhost:${PUSH_REGISTRY_PORT}/${REF}" --insecure 2>/dev/null); do
      local src="localhost:${PUSH_REGISTRY_PORT}/${REF}:${TAG}"
      local dst="${HARBOR_HOSTNAME}/${project}/${REF}:${TAG}"
      if crane copy "${src}" "${dst}" --insecure 2>&1 | grep -v "^$"; then
        pushed=$((pushed + 1))
      else
        skipped=$((skipped + 1))
      fi
    done
  done

  kill "${HAULER_PID}" 2>/dev/null || true
  wait "${HAULER_PID}" 2>/dev/null || true

  echo "    Done: ${pushed} copied, ${skipped} skipped"
}

cmd_push() {
  local target="${1:-all}"
  require_crane

  echo "==> Logging crane into Harbor"
  crane auth login "${HARBOR_HOSTNAME}" \
    -u admin \
    -p "${HARBOR_ADMIN_PASSWORD}"

  if [[ "${target}" == "all" ]]; then
    for store_name in "${!STORE_PROJECT[@]}"; do
      push_one_store "${store_name}"
    done
  else
    if [[ -z "${STORE_PROJECT[${target}]:-}" ]]; then
      echo "ERROR: Unknown store '${target}'."
      echo "Known stores: ${!STORE_PROJECT[*]}"
      exit 1
    fi
    push_one_store "${target}"
  fi

  echo
  echo "==> Push complete. Verify in Harbor: https://${HARBOR_HOSTNAME}"
}

# ---------------------------------------------------------------------------
# Dispatch
# ---------------------------------------------------------------------------
if [[ "$(id -u)" -ne 0 ]]; then
  echo "ERROR: haulerctl must be run as root."
  exit 1
fi

case "${1:-}" in
  sync)    cmd_sync ;;
  serve)   shift; cmd_serve "$@" ;;
  status)  cmd_status ;;
  push)    shift; cmd_push "${1:-all}" ;;
  *)
    echo "Usage: haulerctl {sync|serve [fileserver|registry <store>]|status|push [<store>|all]}"
    exit 1
    ;;
esac
